# Copy to .env and fill in values. Never commit .env.

# --- LLM provider ---
LLM_PROVIDER=openai          # openai | anthropic | gemini
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# --- Embeddings ---
# sentence-transformers | openai | fastembed
EMBEDDING_PROVIDER=sentence-transformers
# Model used by sentence-transformers or fastembed (ignored for openai)
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# --- Retrieval ---
TOP_K=5
# Optional: drop chunks below this relevance score (0.0–1.0, higher = stricter)
# SCORE_THRESHOLD=0.5

# --- Chunking (PDF ingest only) ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Storage ---
INDEX_PATH=data/faiss_index
